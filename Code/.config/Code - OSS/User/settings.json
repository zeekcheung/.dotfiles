{
  "editor.fontFamily": "Maple Mono NF, JetBrains Mono, Consolas",
  "editor.fontSize": 16,
  "editor.fontWeight": "normal",
  "editor.fontLigatures": true,
  "breadcrumbs.enabled": true,
  "workbench.colorCustomizations": {
    "editorBracketHighlight.foreground1": "#e67e89",
    "editorBracketHighlight.foreground2": "#dbbc7f",
    "editorBracketHighlight.foreground3": "#a7c080",
    "editorBracketHighlight.foreground4": "#7fbbb3",
    "editorBracketHighlight.foreground5": "#e69875",
    "editorBracketHighlight.foreground6": "#d699b6"
  },
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.sideBar.location": "left",
  "workbench.tree.indent": 14,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.layoutControl.enabled": false,
  "workbench.activityBar.location": "default",
  "window.autoDetectColorScheme": true,
  "window.commandCenter": false,
  "window.title": "${appName}",
  "window.titleBarStyle": "custom",
  "window.menuBarVisibility": "classic",
  "window.newWindowDimensions": "inherit",
  "window.zoomLevel": 2.5,
  // "editor.cursorStyle": "block",
  "editor.cursorBlinking": "smooth",
  "editor.cursorWidth": 3,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.glyphMargin": true,
  "editor.guides.indentation": true,
  "editor.minimap.autohide": true,
  "editor.minimap.showSlider": "always",
  "editor.inlayHints.padding": true,
  "editor.lineNumbers": "relative",
  "editor.lineHeight": 24,
  "editor.letterSpacing": 0.5,
  "editor.scrollbar.horizontal": "auto",
  "editor.scrollbar.vertical": "auto",
  "editor.smoothScrolling": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  "workbench.settings.editor": "json",
  "editor.autoClosingBrackets": "always",
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.mouseWheelZoom": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.suggest.insertMode": "replace",
  "editor.suggest.preview": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.tabSize": 2,
  "editor.unicodeHighlight.allowedCharacters": {
    "：": true,
    "➕": true
  },
  "editor.unicodeHighlight.allowedLocales": {
    "zh-hans": true,
    "zh-hant": true
  },
  "editor.wordWrapColumn": 120,
  "editor.wordWrap": "wordWrapColumn",
  "zenMode.hideLineNumbers": false,
  "zenMode.showTabs": "none",
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.incrementalNaming": "smart",
  "terminal.external.windowsExec": "",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.autoReplies": {
    "Terminate batch job (Y/N)": "\r"
  },
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.windows": "Windows PowerShell",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.smoothScrolling": true,
  "files.autoGuessEncoding": true,
  "files.associations": {
    ".bashenv": "shellscript",
    ".clangd": "yaml",
    ".shellcheckrc": "properties",
    ".tmux.conf": "shellscript",
    ".vimrc": "Vimscript",
    "*.cjson": "jsonc",
    "*.desktop": "properties",
    "*.env.dev": "env",
    "*.env.prod": "env",
    "*.env.development": "env",
    "*.env.production": "env",
    "*.qss": "css",
    "*.wxss": "css",
    "*.wxs": "javascript",
    "**/.local/bin/*": "shellscript",
    "arch": "shellscript",
    "dunstrc": "properties",
    "fedora": "shellscript",
    "fonts.conf": "xml",
    "keymap.json": "jsonc",
    "settings.json": "jsonc",
    "ubuntu": "shellscript"
  },
  "files.autoSaveDelay": 10000,
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true
  },
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "diffEditor.codeLens": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.ignoreMissingGitWarning": true,
  "git.mergeEditor": true,
  "git.openRepositoryInParentFolders": "never",
  "gitlens.showWelcomeOnInstall": false,
  "gitlens.codeLens.enabled": false,
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "clangd.arguments": [
    "--all-scopes-completion",
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--fallback-style=llvm",
    "--function-arg-placeholders",
    "--header-insertion=iwyu",
    "--header-insertion-decorators",
    "-j=2",
    "--pch-storage=disk",
    "--log=verbose",
    "--pretty"
  ],
  "[rust]": {
    "editor.tabSize": 4
  },
  "html.format.enable": false,
  "html.format.templating": true,
  "html.format.indentHandlebars": true,
  "html.format.indentInnerHtml": true,
  "html.format.wrapLineLength": 80,
  "emmet.triggerExpansionOnTab": true,
  "javascript.format.enable": false,
  "javascript.inlayHints.enumMemberValues.enabled": true,
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.validate.enable": false,
  "typescript.format.enable": false,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "Lua.format.enable": false,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdown.preview.typographer": true,
  "xml.validation.filters": [
    {
      "pattern": "fonts.conf",
      "enabled": false
    }
  ],

  "vim.easymotion": true,
  "vim.easymotionMarkerForegroundColorOneChar": "#ff007c",
  "vim.foldfix": true,
  "vim.gdefault": true,
  "vim.showMarksInGutter": true,
  "vim.targets.enable": true,
  "vim.handleKeys": {
    "<C-a>": true,
    "<C-b>": true,
    "<C-d>": true,
    "<C-u>": true,
    "<C-v>": true,
    "<C-c>": false,
    "<C-e>": false,
    "<C-s>": false,
    "<C-z>": false,
    "<C-x>": false,
    "<C-f>": true,
    "<C-p>": false
  },
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.leader": "<space>",
  "vim.overrideCopy": false,
  "vim.showcmd": true,
  "vim.showmodename": true,
  "vim.smartRelativeLine": false,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,

  // prettier-ignore
  "vim.insertModeKeyBindings": [
    // better escape
    { "before": ["j", "j"], "after": ["<Esc>"] }
  ],
  // prettier-ignore
  "vim.visualModeKeyBindingsNonRecursive": [
    // better indent
    { "before": [">"], "commands": ["editor.action.indentLines"], "silent": true },
    { "before": ["<"], "commands": ["editor.action.outdentLines"], "silent": true },
    // paste without overriding the current register
    { "before": ["p"], "after": ["p", "g", "v", "y"] },
    // surround
    { "before": ["g", "s", "a"], "after": ["S"] }
  ],
  // prettier-ignore
  "vim.normalModeKeyBindings": [
    // undo/redo
    { "before": ["u"], "commands": ["undo"], "silent": true },
    { "before": ["<C-r>"], "commands": ["redo"], "silent": true },
    // goto line
    { "before": ["H"], "after": ["^"] },
    { "before": ["L"], "after": ["$"] },
    // quit
    { "before": ["<leader>", "q", "q"], "commands": [":qa"] },
    { "before": ["<leader>", "q", "w"], "commands": [":exit"] },
    // hover
    { "before": ["K"], "commands": ["editor.action.showHover"], "silent": true },
    // line diagnostic
    { "before": ["<leader>", "d"], "after": ["K"], "silent": true },
    // window navigation
    { "before": ["<c-h>"], "after": ["<c-w>", "h"] },
    { "before": ["<c-j>"], "after": ["<c-w>", "j"] },
    { "before": ["<c-k>"], "after": ["<c-w>", "k"] },
    { "before": ["<c-l>"], "after": ["<c-w>", "l"] },
    // buffers
    { "before": ["<Tab>"], "commands": [":bn"] },
    { "before": ["<S-Tab>"], "commands": [":bp"] },
    { "before": ["<leader>", "b", "d"], "commands": [":bd"] },
    { "before": ["<leader>", "b", "f"], "commands": [":bfirst"] },
    { "before": ["<leader>", "b", "l"], "commands": [":blast"] },
    // tabs
    { "before": ["<leader>", "<tab>", "<tab>"], "commands": [":tabnew"] },
    { "before": ["<leader>", "<tab>", "d"], "commands": [":tabclose"] },
    { "before": ["<leader>", "<tab>", "n"], "commands": [":tabn"] },
    { "before": ["<leader>", "<tab>", "p"], "commands": [":tabp"] },
    { "before": ["<leader>", "<tab>", "f"], "commands": [":tabfirst"] },
    { "before": ["<leader>", "<tab>", "l"], "commands": [":tablast"] },
  ],
  // prettier-ignore
  "vim.normalModeKeyBindingsNonRecursive": [
    // easymotion
    { "before": ["s"], "after": ["leader", "leader", "s"] },
    // toggle explorer
    { "before": ["<leader>", "e"], "commands": ["workbench.action.toggleSidebarVisibility"], "silent": true },
    // code actions
    { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"], "silent": true },
    // rename
    { "before": ["leader", "r", "n"], "commands": ["editor.action.rename"], "silent": true },
    // format
    { "before": ["<leader>", "f", "m"], "commands": ["editor.action.formatDocument"], "silent": true },
    // find file
    { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"], "silent": true },
    // find recent files
    { "before": ["<leader>", "f", "r"], "commands": ["workbench.action.openRecent"], "silent": true },
    // search notifications
    { "before": ["<leader>", "f", "n"], "commands": ["notifications.showList"], "silent": true },
    // search keymaps
    { "before": ["<leader>", "s", "k"], "commands": ["workbench.action.openGlobalKeybindings"], "silent": true },
    // search symbols
    { "before": ["<leader>", "s", "s"], "commands": ["workbench.action.gotoSymbol"], "silent": true },
    // search symbols in Workspace
    { "before": ["<leader>", "s", "S"], "commands": ["workbench.action.showAllSymbols"], "silent": true },
    // search word
    { "before": ["<leader>", "s", "g"], "commands": ["actions.find"], "silent": true },
    // search word(workbench)
    { "before": ["<leader>", "s", "G"], "commands": ["workbench.action.findInFiles"], "silent": true },
    // find themes
    { "before": ["<leader>", "u", "C"], "commands": ["workbench.action.selectTheme"], "silent": true },
    // toggle diagnostics
    { "before": ["<leader>", "u", "d"], "commands": ["workbench.actions.view.problems"], "silent": true },
    // toggle word wrap
    { "before": ["<leader>", "u", "w"], "commands": ["editor.action.toggleWordWrap"], "silent": true },
    // toggle symbol
    { "before": ["leader", "c", "s"], "commands": ["outline.focus", "outline.collapseAll"], "silent": true },
    // toggle git
    { "before": ["<leader>", "g", "g"], "commands": ["workbench.scm.focus"], "silent": true },
    // toggle zen mode
    { "before": ["<leader>", "z"], "commands": ["workbench.action.toggleZenMode"], "silent": true },
  ],

  // prettier-ignore
  "vscode-neovim.ctrlKeysForNormalMode": ["a", "b", "d", "f", "i", "o", "r", "t", "u", "v", "w","x", "]", "right", "left", "up", "down", "backspace", "delete", "h", "j", "k", "l" ],
  // prettier-ignore
  "vscode-neovim.ctrlKeysForInsertMode": [ "b", "d", "f", "i", "o", "r", "t", "u", "w", "]", "right", "left", "up", "down", "backspace", "delete" ],
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape",
      "args": []
    }
  },

  "extensions.closeExtensionDetailsOnViewChange": true,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
    "vscodevim.vim": 1
  },
  "extensions.ignoreRecommendations": true,
  "debug.onTaskErrors": "showErrors",
  "debug.inlineValues": "auto",
  "debug.console.closeOnEnd": true,
  "debug.terminal.clearBeforeReusing": true,
  "remote.downloadExtensionsLocally": true,
  "search.smartCase": true,
  "search.showLineNumbers": true,
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.enabled": false,
  "settingsSync.ignoredSettings": ["-window.zoomLevel"],
  "telemetry.telemetryLevel": "off",
  "task.allowAutomaticTasks": "on",
  "task.problemMatchers.neverPrompt": {
    "shell": true
  },
  "gitlens.launchpad.indicator.enabled": false,
  "window.customTitleBarVisibility": "auto",
  "workbench.startupEditor": "none",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "codeium.enableCodeLens": false,
  "redhat.telemetry.enabled": false
}
