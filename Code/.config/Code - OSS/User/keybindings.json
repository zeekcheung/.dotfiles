// Place your key bindings in this file to override the defaults
[
  // find file
  {
    "key": "space f f",
    "command": "workbench.action.quickOpen",
    "when": "!editorIsOpen && !inputFocus"
  },
  // find recent file
  {
    "key": "space f r",
    "command": "workbench.action.openRecent",
    "when": "!editorIsOpen && !inputFocus"
  },
  // search notifications
  {
    "key": "space s n",
    "command": "notifications.showList",
    "when": "!editorIsOpen && !inputFocus"
  },
  // find theme
  {
    "key": "space u C",
    "command": "workbench.action.selectTheme",
    "when": "!editorIsOpen && !inputFocus"
  },
  // toggle git
  {
    "key": "space g g",
    "command": "workbench.scm.focus",
    "when": "!editorIsOpen && !inputFocus"
  },
  // explorer
  {
    "key": "space e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "(!editorIsOpen && !inputFocus) || (listFocus && !inputFocus && !treestickyScrollFocused)"
  },
  {
    "key": "ctrl+e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "listFocus && !inputFocus && !treestickyScrollFocused"
  },
  {
    "key": "ctrl+e",
    "command": "workbench.explorer.fileView.focus",
    "when": "!explorerViewletVisible"
  },
  {
    "key": "ctrl+e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "explorerViewletVisible"
  },
  {
    "key": "q",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "listFocus && !inputFocus && !treestickyScrollFocused"
  },
  {
    "key": "a",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "shift+a",
    "command": "explorer.newFolder",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "d",
    "command": "deleteFile",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "r",
    "command": "renameFile",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "y",
    "command": "filesExplorer.copy",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
  },
  {
    "key": "x",
    "command": "filesExplorer.cut",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !inputFocus"
  },
  {
    "key": "p",
    "command": "filesExplorer.paste",
    "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "v",
    "command": "explorer.openToSide",
    "when": "explorerViewletFocus && explorerViewletVisible && !inputFocus"
  },
  {
    "key": "/",
    "command": "list.find",
    "when": "listFocus && listSupportsFind && !inputFocus"
  },
  {
    "key": "z o",
    "command": "list.expand",
    "when": "!editorTextFocus && !inputFocus"
  },
  {
    "key": "z c",
    "command": "list.collapse",
    "when": "!editorTextFocus && !inputFocus"
  },
  {
    "key": "z shift+c",
    "command": "list.collapseAllToFocus",
    "when": "!editorTextFocus && !inputFocus"
  },
  {
    "key": "z a",
    "command": "list.toggleExpand",
    "when": "!editorTextFocus && !inputFocus"
  },
  {
    "key": "z m",
    "command": "list.collapseAll",
    "when": "!editorTextFocus && !inputFocus"
  },
  // move line
  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  // go back to editor
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "explorerViewletVisible && filesExplorerFocus"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "searchViewletVisible && searchViewletFocus"
  },
  // {
  //   "key": "ctrl+l",
  //   "command": "workbench.action.focusActiveEditorGroup",
  //   "when": "viewContainer.workbench.view.extensions.enabled"
  // },
  {
    "key": "ctrl+k",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminal.active"
  },
  // quick input
  {
    "key": "ctrl+n",
    "command": "quickInput.next",
    "when": "inQuickInput && quickInputType == 'quickPick'"
  },
  {
    "key": "ctrl+p",
    "command": "quickInput.previous",
    "when": "inQuickInput && quickInputType == 'quickPick'"
  },
  // suggestion
  {
    "key": "ctrl+f",
    "command": "editor.action.inlineSuggest.commit",
    "when": "editorTextFocus && !suggestionWidgetVisible && (vim.mode == 'Insert' || neovim.mode == insert)"
  },
  {
    "key": "ctrl+c",
    "command": "hideSuggestWidget",
    "when": "suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "tab",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "shift+tab",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "ctrl+n",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "ctrl+p",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  // hover
  {
    "key": "q",
    "command": "editor.action.showHover",
    "when": "editorHoverVisible && (vim.mode == 'Normal' || neovim.mode == normal)"
  },
  // diagnostic
  {
    "key": "oem_6 d",
    "command": "editor.action.marker.nextInFiles",
    "when": "editorFocus && (vim.mode == 'Normal' || neovim.mode == normal)"
  },
  {
    "key": "oem_6 d",
    "command": "editor.action.marker.prevInFiles",
    "when": "editorFocus && (vim.mode == 'Normal' || neovim.mode == normal)"
  },
  // split
  {
    "key": "oem_5",
    "command": "workbench.action.splitEditor",
    "when": "editorFocus && (vim.mode == 'Normal' || neovim.mode == normal)"
  },
  {
    "key": "shift+oem_5",
    "command": "workbench.action.splitEditorDown",
    "when": "editorFocus && (vim.mode == 'Normal' || neovim.mode == normal)"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.terminal.focusFind",
    "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
  },
  {
    "key": "ctrl+f",
    "command": "-workbench.action.terminal.focusFind",
    "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
  }
]
