#!/usr/bin/env bash

# Script to install zsh plugins

set -e

PLUGINS_DIR="/usr/share/zsh/plugins"

sudo git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions $PLUGINS_DIR/zsh-autosuggestions
sudo git clone --depth=2 https://github.com/zsh-users/zsh-syntax-highlighting $PLUGINS_DIR/zsh-syntax-highlighting
sudo git clone --depth=1 https://github.com/zsh-users/zsh-completions $PLUGINS_DIR/zsh-completions
