// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "vim_mode": true,
  "cursor_blink": false,
  "relative_line_numbers": true,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_features": {
    "calt": true
  },
  "buffer_font_size": 16,
  "ui_font_size": 16,
  "tab_size": 2,
  "confirm_quit": false,
  "current_line_highlight": "line",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Andromeda"
  },
  "indent_guides": {
    "enabled": true
  },
  "scrollbar": {
    "show": "auto"
  },
  "gutter": {
    "code_actions": false,
    "folds": true,
    "runnables": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "file_icons": true
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "terminal": {
    "dock": "bottom",
    "copy_on_select": true,
    "font_family": "Maple Mono NF",
    "font_features": {
      "calt": true
    },
    "line_height": "standard",
    "toolbar": {
      "title": true
    }
  },
  "project_panel": {
    "scrollbar": {
      "show": "never"
    }
  },
  "assistant": {
    "version": "2",
    "enabled": false,
    "button": false
  },
  "features": {
    "inline_completion_provider": "none"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "journal": {
    "hour_format": "hour24"
  },
  "file_types": {
    "Shell Script": ["conf"],
    "JSONC": ["settings.json"],
    "XML": ["fonts.conf"]
  }
}
